RELAYDESK_NAME=RelayDesk
RELAYDESK_HOST=0.0.0.0
RELAYDESK_PORT=3000
RELAYDESK_PASSWORD=change-this-workspace-password
RELAYDESK_SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters
RELAYDESK_CREDENTIALS_KEY=replace-with-a-different-random-secret-at-least-32-characters
# Set true only behind HTTPS. Keep false for local and plain-HTTP LAN deployments.
RELAYDESK_COOKIE_SECURE=false
RELAYDESK_DATA_DIR=./data
# Set false for a general-purpose Hermes Web UI without content operations.
RELAYDESK_RUNTIME_TYPE=mock
# Hermes API Server. Start Hermes Gateway with API_SERVER_ENABLED=1 and API_SERVER_KEY.
# RELAYDESK_HERMES_BASE_URL=http://hermes.internal:8642
# RELAYDESK_HERMES_API_KEY=replace-with-the-api-server-key
# RELAYDESK_HERMES_TIMEOUT_MS=120000
# Permit only Hermes-host directories that RelayDesk may archive when Hermes returns MEDIA:/absolute/path.
# RELAYDESK_RUNTIME_SHARED_PATHS=/srv/hermes-artifacts,/srv/hermes-uploads
# Runtime API 主机白名单。内网其他 Agent IP/域名必须显式加入，防止服务端请求伪造。
RELAYDESK_RUNTIME_ALLOWED_HOSTS=127.0.0.1,localhost,::1,host.docker.internal
# Upload limits in bytes. Images use the lower image-specific limit.
RELAYDESK_MAX_UPLOAD_BYTES=52428800
RELAYDESK_MAX_IMAGE_BYTES=20971520
